            self.status_label.setText("Ready")
            if hasattr(self, 'plotter_placeholder') and self.plotter is None:
                self.plotter_placeholder.setText("Ready")

    def on_recording_finished(self, video_path):
        """Called when recording completes"""
        # Prompt user for filename
        from datetime import datetime
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        default_name = f"paddle_swing_{timestamp}.mp4"
        
        filename, ok = QInputDialog.getText(
            self,
            "Save Video As",
            f"Enter video filename (default: {default_name}):",
            text=default_name
        )
        
        if ok and filename:
            # Ensure .mp4 extension
            if not filename.endswith('.mp4'):
                filename += '.mp4'
            
            new_path = os.path.join(SCRIPT_DIR, filename)
            
            try:
                os.rename(video_path, new_path)
                self.video_path = new_path
                QMessageBox.information(self, "Saved", f"Video saved as:\n{filename}")
            except Exception as e:
                QMessageBox.warning(self, "Error", f"Could not rename file:\n{e}")
        
        # Refresh video list
        self.refresh_video_list()

    def on_recording_error(self, error_msg):
        """Called when recording fails"""
        QMessageBox.critical(self, "Recording Error", error_msg)

    def refresh_video_list(self):
        """Refresh the list of available videos"""
        self.video_list.clear()
        if os.path.exists(SCRIPT_DIR):
            for file in os.listdir(SCRIPT_DIR):
                if file.endswith('.mp4'):
                    self.video_list.addItem(file)

