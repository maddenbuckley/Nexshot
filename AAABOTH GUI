    def start_recording(self, mode):
        if self.worker and self.worker.isRunning():
            return

        name = self.name_input.text().strip()
        if not name:
            QMessageBox.warning(self, "Error", "Enter a video name")
            return

        self.video_path = os.path.join(SCRIPT_DIR, f"{name}.mp4")

        # Clear old data
        ax_data.clear(); ay_data.clear(); az_data.clear()
        gx_data.clear(); gy_data.clear(); gz_data.clear()

        # Create and start worker
        self.worker = RecordingWorker(self.video_path, mode)
        self.worker.status_update.connect(self.update_status)
        self.worker.finished.connect(self.on_recording_finished)
        self.worker.error.connect(self.on_recording_error)
        self.worker.start()

    def update_status(self, message):
        """Update status label and log list"""
        self.status_label.setText(message)

        # Add to status history log with color-coding
        if hasattr(self, 'status_log'):
            item = QListWidgetItem(message)

            if any(flag in message.lower() for flag in ['error', 'failed', 'not found']):
                item.setForeground(Qt.red)
            elif any(flag in message.lower() for flag in ['success', 'complete', 'connected', 'recording finished']):
                item.setForeground(Qt.darkGreen)
            elif any(flag in message.lower() for flag in ['scanning', 'connecting', 'recording', 'creating animation']):
                item.setForeground(Qt.darkBlue)
            else:
                item.setForeground(Qt.black)

            self.status_log.addItem(item)
            # Keep recent 50 entries to avoid huge list
            while self.status_log.count() > 50:
                self.status_log.takeItem(0)
            self.status_log.scrollToBottom()

        # Also display status in the plotter placeholder / white area
        if hasattr(self, 'plotter_placeholder') and self.plotter is None:
            self.plotter_placeholder.setText(message)

    def on_media_error(self, error):
        """Handle QMediaPlayer errors by falling back to OpenCV playback"""
        err_msg = self.media_player.errorString()
        self.update_status(f"⚠️ Embedded player failed: {err_msg}. Using OpenCV fallback.")
        if hasattr(self, 'current_video_path') and self.current_video_path:
            self.play_video(self.current_video_path)
        # Show plotter if it was hidden
        if hasattr(self, 'plotter') and self.plotter:
            self.plotter.interactor.show()

    def on_media_state_changed(self, state):
        """Handle media player state changes"""
        from PyQt5.QtMultimedia import QMediaPlayer
        if state == QMediaPlayer.StoppedState:
            # Show plotter when video stops
            if hasattr(self, 'plotter') and self.plotter:
                self.plotter.interactor.show()

    def clear_status_log(self):
