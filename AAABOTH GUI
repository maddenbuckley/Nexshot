# ---------------- WORKER THREAD ----------------
class RecordingWorker(QThread):
    """Worker thread for BLE recording and animation"""
    status_update = pyqtSignal(str)  # Status messages
    finished = pyqtSignal(str)  # Video path when done
    error = pyqtSignal(str)  # Error messages

    def __init__(self, video_path, mode="BLE"):
        super().__init__()
        self.video_path = video_path
        self.mode = mode

    def run(self):
        """Run the recording and animation pipeline"""
        try:
            self.status_update.emit("🔄 Starting recording...")
            
            # Run async recording
            try:
                asyncio.run(self._async_pipeline())
            except RuntimeError:
                # Handle event loop issues
                loop = asyncio.new_event_loop()
                asyncio.set_event_loop(loop)
                loop.run_until_complete(self._async_pipeline())
                loop.close()

        except Exception as e:
            self.status_update.emit(f"[!] Error: {e}")
            import traceback
            self.status_update.emit(traceback.format_exc())
            self.error.emit(str(e))

    async def _async_pipeline(self):
        """Async pipeline implementation"""
        # Record motion (live UI status updates)
        if self.mode == "BLE":
            await record_motion_ble(lambda msg: self.status_update.emit(msg))
        else:
            record_motion_serial(lambda msg: self.status_update.emit(msg))

        if len(ax_data) < 5:
            self.status_update.emit("❌ Not enough data")
            self.error.emit("Not enough motion data recorded")
            return
        if len(ax_data) == 0:
            self.status_update.emit("❌ Device not found")
            self.error.emit("BLE device not found")
            return

        self.status_update.emit(f"[✓] Recorded {len(ax_data)} samples")

        # Process data
        ax, ay, az, gx, gy, gz = resample_data(
            ax_data, ay_data, az_data, gx_data, gy_data, gz_data
        )

        orientations = compute_orientation(ax, ay, az, gx, gy, gz)
        positions = compute_swing_translation(orientations, ax, ay, az)

        if self.mode == "SERIAL":
            positions = smooth_positions(positions, window=61, polyorder=3)
            orientations = smooth_orientations(orientations, alpha=0.85)
        else:
            positions = smooth_positions(positions, window=41, polyorder=3)
            orientations = smooth_orientations(orientations, alpha=0.65)

        if self.mode == "SERIAL":
            positions = positions - np.mean(positions, axis=0)  # Center around origin for serial mode

            max_range = np.max(np.linalg.norm(positions, axis=1))
            if max_range > 0:
                positions = positions / max_range * 0.2  # Scale to fit in view

            positions *= 0.5  # Additional scaling for serial mode

        if self.mode == "SERIAL":
            target_frames = int(RECORD_TIME * ANIMATION_FPS)
        else:
            target_frames = int(RECORD_TIME * ANIMATION_FPS * 1.2)
        orientations, positions = interpolate_motion(
            orientations, positions, target_frames
        )

        self.status_update.emit("[*] Creating animation...")

        # Create animation (this part is synchronous)
        self._create_animation(orientations, positions)

        self.status_update.emit("✅ Animation complete!")
        self.finished.emit(self.video_path)

    def _create_animation(self, orientations, positions):
        """Create the animation synchronously (match Accelerometer.py style)"""
        print("Starting animation creation")
        try:
            mesh = pv.read(STL_FILE)
            print("Loaded mesh successfully")
        except Exception as e:
            print(f"Failed to load STL: {e}")
            return
        
        handle_offset = np.array([0.15, 0, 0])
        mesh.translate(-handle_offset)
        mesh.rotate_y(90)
        if self.mode == "SERIAL":
            mesh.scale([0.35, 0.35, 0.35])
        else:
            mesh.scale([1.0, 1.0, 1.0])
        print(f"Mesh bounds after transform: {mesh.bounds}")

        plotter = pv.Plotter(off_screen=True, window_size=(912, 704))
        actor = plotter.add_mesh(mesh, color="darkgreen", smooth_shading=True)
        plotter.set_background("white")
        plotter.add_axes()

        paddle_bounds = mesh.bounds
        motion_bounds_min = positions.min(axis=0)
        motion_bounds_max = positions.max(axis=0)
        print(f"Motion bounds min: {motion_bounds_min}, max: {motion_bounds_max}")

        bounds_min = np.minimum(paddle_bounds[::2], motion_bounds_min)
        bounds_max = np.maximum(paddle_bounds[1::2], motion_bounds_max)
        center = (bounds_min + bounds_max) / 2
        swing_size = np.linalg.norm(bounds_max - bounds_min)
        print(f"Total bounds min: {bounds_min}, max: {bounds_max}, center: {center}, swing_size: {swing_size}")

        if self.mode == "SERIAL":
            cam_dist = swing_size * 3 + 8  # Cap distance for serial mode
        else:
            cam_dist = swing_size * 2.5 + 6
        camera_pos = (
            center[0] + cam_dist,
            center[1] + cam_dist,
            center[2] + cam_dist * 0.8,
        )
        focal_point = center
        view_up = (0, 0, 1)

        plotter.camera_position = [camera_pos, focal_point, view_up]
        plotter.camera.zoom(0.9)
        print(f"Camera position: {camera_pos}, focal: {focal_point}")

        writer = imageio.get_writer(self.video_path, fps=ANIMATION_FPS, macro_block_size=16, 
                                   format='mp4', codec='libx264', 
                                   quality=8, pixelformat='yuv420p')

        prev_rot = None

        try:
            for i, (orientation, pos) in enumerate(zip(orientations, positions)):
                if prev_rot is None:
                    smooth_orientation = orientation
                else:
                    key_rots = R.concatenate([prev_rot, orientation])
                    slerp = Slerp([0, 1], key_rots)
                    smooth_orientation = slerp([0.2])[0]

                prev_rot = smooth_orientation
                rot = smooth_orientation.as_euler("xyz", degrees=True)

                actor.SetOrientation(rot)
                actor.SetPosition(pos)
                with vtk_lock:  # Ensure VTK context is never used concurrently
                    plotter.render()
                    frame = plotter.screenshot(return_img=True)
                writer.append_data(frame)

                if i % 50 == 0:
                    progress = (i / len(orientations)) * 100
                    self.status_update.emit(f"[*] Rendering: {progress:.1f}%")
                    print(f"Rendered frame {i}, pos: {pos}, rot: {rot}")

        except Exception as e:
            print(f"Error during animation: {e}")
            import traceback
            traceback.print_exc()
        finally:
            writer.close()
            with vtk_lock:
                plotter.close()
            del plotter
            print("Animation creation finished")


