    def play_embedded_video(self, video_path):
        """Play the video using OpenCV (reliable playback)"""
        self.play_video(video_path)

    def play_control(self):
        if self.media_player.media().isNull() and getattr(self, 'current_video_path', None):
            self.play_embedded_video(self.current_video_path)
            return

        self.media_player.play()
        self.status_label.setText("▶ Playback resumed")

    def pause_control(self):
        self.media_player.pause()
        self.status_label.setText("⏸ Playback paused")

    def stop_control(self):
        self.media_player.stop()
        self.status_label.setText("⏹ Playback stopped")

    def toggle_speed_control(self):
        speed_map = {1.0: 1.5, 1.5: 2.0, 2.0: 0.5, 0.5: 1.0}
        self._playback_speed = speed_map.get(self._playback_speed, 1.0)
        self.media_player.setPlaybackRate(self._playback_speed)
        self.speed_control_btn.setText(f"Speed x{self._playback_speed}")
        self.status_label.setText(f"⚡ Speed set to {self._playback_speed}x")

    def watch_most_recent_video(self):
        """Play the most recently recorded video without opening file explorer"""
        self.update_status("▶ Watch button clicked")

        # Ensure list is up to date
        self.refresh_video_list()

        # Priority 1: current latest recording path from this session
        if getattr(self, 'video_path', None) and os.path.exists(self.video_path):
            self.update_status(f"▶ Playing current video: {os.path.basename(self.video_path)}")
            self.play_embedded_video(self.video_path)
            return

        # Priority 2: most recent MP4 in list
        if self.video_list.count() > 0:
            last_item = self.video_list.item(self.video_list.count() - 1)
            if last_item:
                video_path = os.path.join(SCRIPT_DIR, last_item.text())
                if os.path.exists(video_path):
                    self.update_status(f"▶ Playing latest from list: {last_item.text()}")
                    self.play_embedded_video(video_path)
                    return

        # Priority 3: Open dialog fallback
        filename, _ = QFileDialog.getOpenFileName(
            self,
            "Select Video File to Watch",
            SCRIPT_DIR,
            "Video Files (*.mp4 *.avi *.mov)"
        )
        if filename:
