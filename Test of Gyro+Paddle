import numpy as np
import pyvista as pv
from datetime import datetime
import time
import imageio.v2 as imageio

STL_FILE = r"C:\Users\Brooke\Downloads\VS Code\Captone Spring\paddle.stl"
OUT_VIDEO = "paddle_animation.mp4"

# ----------------------------------------
# Example: replace these with your real data
# ----------------------------------------
def load_gyro_data():
    # Replace with your CSV loader
    gx = np.array([52.6, 52.0, 53.1, 54.5, 54.8, 52.9, 45.5, 32.7, 14.2, -9.0])
    gy = np.array([-1.2, -1.3, -1.6, -1.9, -1.9, -1.3, 0.8, 4.4, 9.3, 15.1])
    gz = np.array([8.1, 8.1, 7.8, 7.5, 7.5, 8.1, 10.1, 13.2, 17.6, 22.7])
    ts = np.linspace(0, 10, len(gx))  # 10 seconds total
    return gx, gy, gz, ts

# ----------------------------------------
# Simple low-pass smoothing
# ----------------------------------------
def smooth(x, alpha=0.2):
    y = np.zeros_like(x)
    y[0] = x[0]
    for i in range(1, len(x)):
        y[i] = alpha * x[i] + (1 - alpha) * y[i - 1]
    return y

# ----------------------------------------
# Animation Export
# ----------------------------------------
def animate_paddle(gx, gy, gz, ts):
    plotter = pv.Plotter(off_screen=True, window_size=(912, 704))
    mesh = pv.read(STL_FILE)
    mesh.translate(-np.array(mesh.center), inplace=True)

    actor = plotter.add_mesh(mesh, color="lightblue", smooth_shading=True)
    plotter.set_background("white")
    plotter.camera_position = "iso"

    writer = imageio.get_writer(OUT_VIDEO, fps=30)

    angles = np.array([0.0, 0.0, 0.0])  # roll, pitch, yaw in degrees

    for i in range(1, len(ts)):
        dt = ts[i] - ts[i - 1]

        angles[0] += gx[i] * dt
        angles[1] += gy[i] * dt
        angles[2] += gz[i] * dt

        mesh.points = mesh.copy().points
        mesh.rotate_x(angles[0], inplace=True)
        mesh.rotate_y(angles[1], inplace=True)
        mesh.rotate_z(angles[2], inplace=True)

        plotter.render()
        frame = plotter.screenshot(return_img=True)
        writer.append_data(frame)

    writer.close()
    plotter.close()
    print(f"[✓] Animation exported: {OUT_VIDEO}")

# ----------------------------------------
# Main
# ----------------------------------------
def main():
    gx, gy, gz, ts = load_gyro_data()

    gx = smooth(gx)
    gy = smooth(gy)
    gz = smooth(gz)

    animate_paddle(gx, gy, gz, ts)

if __name__ == "__main__":
    main()
