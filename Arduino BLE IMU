#include <ArduinoBLE.h>
#include <Arduino_LSM9DS1.h>

BLEService customService("19B10000-E8F2-537E-4F6C-D104768A1214");
BLEStringCharacteristic ble_imu("19B10001-E8F2-537E-4F6C-D104768A1214", BLERead | BLENotify, 24);

char imuBuffer[80];  // safer than String

void setup() {
  Serial.begin(115200);
  //while (!Serial);  // Wait for Serial Monitor to open (optional)

  // Print CSV header
  //Serial.println("ax,ay,az,gx,gy,gz");

  if (!IMU.begin()) {
    Serial.println("Failed to initialize IMU!");
    while (1);
  }

  Serial.println("IMU initialized");

  if (!BLE.begin()) {
    Serial.println("BLE failed");
    while (1);
  }

  BLE.setLocalName("Nano33BLE_IMU");
  BLE.setAdvertisedService(customService);
  
  customService.addCharacteristic(ble_imu);
  BLE.addService(customService);
  
  BLE.advertise();
  
  Serial.println("BLE advertising...");
}

void loop() {
  BLEDevice central = BLE.central();

  if (central) {
    Serial.print("Connected to: ");
    Serial.println(central.address());

    while (central.connected()){
      sendIMU();
      //Send BLE notification
      ble_imu.writeValue(imuBuffer);

      delay(5); //~100-200 Hz loop speed
    }
    Serial.println("Central disconnected");
  }
}

// IMU Read
void sendIMU() {
  float ax, ay, az;
  float gx, gy, gz;

  // Only read when new data is available
  if (IMU.accelerationAvailable() && IMU.gyroscopeAvailable()){
    IMU.readAcceleration(ax, ay, az);
    IMU.readGyroscope(gx, gy, gz);

    snprintf(imuBuffer, sizeof(imuBuffer), "%.3f,%.3f,%.3f,%.3f,%.3f,%.3f", ax, ay, az, gx, gy, gz);

    Serial.println(imuBuffer);
  }
}
