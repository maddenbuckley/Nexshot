import os
import asyncio
import time
import numpy as np
import pyvista as pv
import imageio
from bleak import BleakScanner, BleakClient
from scipy.signal import savgol_filter
from scipy.interpolate import CubicSpline
from scipy.spatial.transform import Rotation as R, Slerp

# ---------------- CONFIG ----------------
DEVICE_NAME = "Nano33BLE_IMU"
CHAR_UUID = "19B10001-E8F2-537E-4F6C-D104768A1214"

RECORD_TIME = 10
ANIMATION_FPS = 60
SMOOTH_WINDOW = 25

# Motion scaling
X_SCALE = 10
Y_SCALE = 8
Z_SCALE = 8

GYRO_WEIGHT = 0.98

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
STL_FILE = os.path.join(SCRIPT_DIR, "paddle.stl")
VIDEO_OUT = os.path.join(SCRIPT_DIR, "paddle_swing_demo.mp4")

# ---------------- DATA STORAGE ----------------
ax_data, ay_data, az_data = [], [], []
gx_data, gy_data, gz_data = [], [], []

# ---------------- BLE RECORDING ----------------
async def record_motion():

    print("Scanning for device...")
    devices = await BleakScanner.discover()
    device = next((d for d in devices if d.name == DEVICE_NAME), None)

    if not device:
        print("Device not found")
        return

    print("Connecting to", device.address)

    async with BleakClient(device.address) as client:

        def notification_handler(sender, data):

            try:
                text = data.decode().strip()
                vals = text.replace(",", " ").split()

                if len(vals) < 6:
                    return

                ax, ay, az, gx, gy, gz = map(float, vals[:6])

                ax_data.append(ax)
                ay_data.append(ay)
                az_data.append(az)

                gx_data.append(gx)
                gy_data.append(gy)
                gz_data.append(gz)

            except:
                pass

        print("Recording Motion...")
        await client.start_notify(CHAR_UUID, notification_handler)

        await asyncio.sleep(RECORD_TIME)

        await client.stop_notify(CHAR_UUID)

    print("Recording finished")
    print("Samples captured:", len(ax_data))
    print("Sample rate:", len(ax_data) / RECORD_TIME, "Hz")

# ---------------- SMOOTH ----------------
def smooth_data(data):

    if len(data) < SMOOTH_WINDOW:
        return np.array(data)

    return savgol_filter(data, SMOOTH_WINDOW, 3)

# ---------------- ORIENTATION ----------------
def compute_orientation():

    ax = smooth_data(ax_data)
    ay = smooth_data(ay_data)
    az = smooth_data(az_data)

    gx = smooth_data(gx_data)
    gy = smooth_data(gy_data)
    gz = smooth_data(gz_data)

    orientations = []
    orientation = R.identity()

    dt = RECORD_TIME / len(ax) 

    for i in range(len(ax)):

        gyro_vec = np.array([gx[i], gy[i], gz[i]]) * np.pi/180 * dt
        gyro_rot = R.from_rotvec(gyro_vec)

        orientation = orientation * gyro_rot

        g = np.array([ax[i], ay[i], az[i]])
        g /= np.linalg.norm(g)

        pitch = np.arctan2(-g[0], np.sqrt(g[1]**2 + g[2]**2))
        roll = np.arctan2(g[1], g[2])

        accel_rot = R.from_euler('xy', [pitch, roll])

        key_times = [0,1]
        key_rots = R.concatenate([orientation, accel_rot])

        slerp = Slerp(key_times, key_rots)
        orientation = slerp([GYRO_WEIGHT])[0]

        orientations.append(orientation)

    base = orientations[0].inv()
    orientations = [base * o for o in orientations]

    return orientations

# ---------------- TRANSLATION ----------------
def compute_swing_translation(orientations):

    positions = []

    for orientation in orientations:

        pitch, roll, yaw = orientation.as_euler("xyz", degrees=True)

        x = pitch * 0.15 * X_SCALE
        y = yaw * 0.15 * Y_SCALE
        z = roll * 0.15 * Z_SCALE

        tip_offset = np.array([0.35, 0, 0])
        tip_world = orientation.apply(tip_offset)
        
        positions.append([x,y,z] + tip_world)

    positions = np.array(positions)

    for i in range(3):
        positions[:, i] = savgol_filter(positions[:, i], 11, 3)

    return positions

# -------- INTERPOLATE FOR SMOOTHER MOTION --------
def interpolate_motion(orientations, positions, target_frames):
    """
    Interpolate orientations and positions using cubic splines
    to create smoother motion with more frames
    """
    n_keyframes = len(orientations)
    
    if n_keyframes < 4:
        return orientations, positions  # Not enough data to interpolate
    
    # Use time as parameter for interpolation
    time_original = np.linspace(0, 1, n_keyframes)
    time_interp = np.linspace(0, 1, target_frames)
    
    # Convert orientations to Euler angles for interpolation
    euler_angles = np.array([o.as_euler("xyz", degrees=True) for o in orientations])
    
    # Interpolate each Euler angle using cubic spline
    interp_euler = np.zeros((target_frames, 3))
    for i in range(3):
        cs = CubicSpline(time_original, euler_angles[:, i])
        interp_euler[:, i] = cs(time_interp)
    
    # Convert back to Rotation objects
    interp_orientations = [R.from_euler("xyz", e, degrees=True) for e in interp_euler]
    
    # Interpolate positions using cubic spline
    interp_positions = np.zeros((target_frames, 3))
    for i in range(3):
        cs = CubicSpline(time_original, positions[:, i])
        interp_positions[:, i] = cs(time_interp)
    
    return interp_orientations, interp_positions

# -------- ANIMATION --------
def animate_paddle():
    if len(ax_data) < 5:
        print("Not enough motion data")
        return

    # compute orientation and positions
    orientations = compute_orientation()
    positions = compute_swing_translation(orientations)
    path = pv.Spline(positions, 200)
    
    # Interpolate for smoother motion (minimal interpolation for 10-second animation)
    target_frames = int(RECORD_TIME * ANIMATION_FPS)  # Keep animation at original duration
    print(f"Interpolating from {len(orientations)} frames to {target_frames} frames...")
    orientations, positions = interpolate_motion(orientations, positions, target_frames)

    # read paddle mesh
    mesh = pv.read(STL_FILE)
    mesh.translate(-np.array(mesh.center))
    mesh.rotate_y(90)

    # scale paddle for visibility
    mesh.scale([0.35, 0.35, 0.35])

    plotter = pv.Plotter(off_screen=True, window_size=(912, 704))
    actor = plotter.add_mesh(
        mesh,
        color="darkgreen",
        smooth_shading=True
    )
    plotter.set_background("white")
    #plotter.add_mesh(path, color="red", line_width=4)
    plotter.add_axes()

    # ---------------- GRID ----------------
    paddle_bounds = mesh.bounds  # (xmin,xmax, ymin,ymax, zmin,zmax)
    motion_bounds_min = positions.min(axis=0)
    motion_bounds_max = positions.max(axis=0)

    # combine bounds for full scene
    bounds_min = np.minimum(paddle_bounds[::2], motion_bounds_min)
    bounds_max = np.maximum(paddle_bounds[1::2], motion_bounds_max)
    center = (bounds_min + bounds_max) / 2
    swing_size = np.linalg.norm(bounds_max - bounds_min)

    # ---------------- CAMERA ----------------
    cam_dist = swing_size * 2.5 + 6

    camera_pos = (
        center[0] + cam_dist,
        center[1] + cam_dist,
        center[2] + cam_dist * 0.8   # side view to emphasize X-axis motion
    )

    focal_point = center

    view_up = (0, 0, 1)

    plotter.camera_position = [camera_pos, focal_point, view_up]

    plotter.camera.zoom(0.9)

    print(plotter.camera_position)

    writer = imageio.get_writer(VIDEO_OUT, fps=ANIMATION_FPS)

    print("Rendering animation...")
    prev_rot = None

    for orientation, pos in zip(orientations, positions):
        rot = orientation.as_euler("xyz", degrees=True)
        if prev_rot is not None:
            rot = prev_rot * 0.7 + np.array(rot) * 0.3
        prev_rot = rot

        # update paddle
        actor.SetOrientation(rot)
        actor.SetPosition(pos)

        plotter.render()
        frame = plotter.screenshot(return_img=True)

        writer.append_data(frame)

    writer.close()
    plotter.close()
    print("Video saved:", VIDEO_OUT)

# ---------------- MAIN ----------------
async def main():

    await record_motion()
    animate_paddle()

if __name__ == "__main__":
    asyncio.run(main())
