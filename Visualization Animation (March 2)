import asyncio
from bleak import BleakClient, BleakScanner
import matplotlib.pyplot as plt
from matplotlib.animation import FuncAnimation
from mpl_toolkits.mplot3d import Axes3D
import numpy as np
import csv
from datetime import datetime
from scipy.signal import savgol_filter

# ============ BLE Configuration ============
DEVICE_NAME = "Nano33BLE_IMU"
CHARACTERISTIC_UUID = "19B10001-E8F2-537E-4F6C-D104768A1214"

# ============ Recording Parameters ============
RECORDING_DURATION = 10  # seconds
BLE_READ_INTERVAL = 0.03  # ~33 Hz

# ============ Signal Processing (Smoothing) ============
ACCELERATION_SCALE = 0.1
LOW_PASS_ALPHA = 0.05          # Lower = smoother (0.05 is more aggressive than 0.1)
MOVING_AVG_WINDOW = 7          # Increased from 5 for more smoothing
SAVGOL_WINDOW = 11             # Savitzky-Golay window size (must be odd)
SAVGOL_POLYORDER = 3           # Polynomial order
USE_SAVGOL = True              # Use Savitzky-Golay for extra smoothing
TRAIL_LENGTH = 30


async def connect_and_record_imu(duration=RECORDING_DURATION):
    """
    Connect to Arduino Nano via BLE and record IMU data (accelerometer + gyroscope)
    
    Args:
        duration: Recording time in seconds
        
    Returns:
        Dictionary with accelerometer (ax, ay, az) and gyroscope (gx, gy, gz) data
    """
    print(f"\n[*] Scanning for BLE devices...")
    devices = await BleakScanner.discover()
    
    # Find target device
    target_device = None
    for device in devices:
        if device.name == DEVICE_NAME:
            target_device = device
            break
    
    if not target_device:
        print(f"[!] Device '{DEVICE_NAME}' not found")
        print(f"[*] Available devices: {[d.name for d in devices if d.name]}")
        return None
    
    print(f"[✓] Found {DEVICE_NAME} at {target_device.address}")
    
    # Connect and record data
    accel_data = {"x": [], "y": [], "z": []}
    gyro_data = {"x": [], "y": [], "z": []}
    timestamps = []
    
    try:
        async with BleakClient(target_device.address) as client:
            print(f"[✓] Connected to {DEVICE_NAME}")
            print(f"[*] Recording for {duration} seconds...")
            
            start_time = asyncio.get_event_loop().time()
            frame_count = 0
            
            while asyncio.get_event_loop().time() - start_time < duration:
                try:
                    # Read data from BLE characteristic
                    value = await client.read_gatt_char(CHARACTERISTIC_UUID)
                    data_string = value.decode("utf-8").strip()
                    
                    if data_string:
                        # Parse: ax, ay, az, gx, gy, gz
                        values = list(map(float, data_string.split(",")))
                        if len(values) >= 6:
                            ax, ay, az, gx, gy, gz = values[:6]
                            
                            # Store data
                            accel_data["x"].append(ax)
                            accel_data["y"].append(ay)
                            accel_data["z"].append(az)
                            gyro_data["x"].append(gx)
                            gyro_data["y"].append(gy)
                            gyro_data["z"].append(gz)
                            timestamps.append(asyncio.get_event_loop().time() - start_time)
                            
                            frame_count += 1
                            if frame_count % 10 == 0:
                                print(f"  [{frame_count}] ax={ax:.2f}, ay={ay:.2f}, az={az:.2f}")
                
                except ValueError as e:
                    print(f"[!] Parse error: {e}")
                
                await asyncio.sleep(BLE_READ_INTERVAL)
            
            print(f"[✓] Recording complete. Captured {frame_count} frames")
            
    except Exception as e:
        print(f"[!] Error during recording: {e}")
        return None
    
    return {
        "accel": accel_data,
        "gyro": gyro_data,
        "timestamps": timestamps
    }


def smooth_data(data):
    """
    Apply multi-stage smoothing: low-pass filter → moving average → Savitzky-Golay
    
    Args:
        data: Dictionary with x, y, z arrays
        
    Returns:
        Smoothed data dictionary
    """
    smoothed = {"x": [], "y": [], "z": []}
    
    for axis in ["x", "y", "z"]:
        # Stage 1: Low-pass filter (IIR - infinite impulse response)
        filtered = []
        prev = 0.0
        for value in data[axis]:
            curr = LOW_PASS_ALPHA * value + (1 - LOW_PASS_ALPHA) * prev
            filtered.append(curr)
            prev = curr
        
        # Stage 2: Moving average
        kernel = np.ones(MOVING_AVG_WINDOW) / MOVING_AVG_WINDOW
        smoothed_ma = np.convolve(filtered, kernel, mode='same')
        
        # Stage 3: Savitzky-Golay filter (preserves peaks while smoothing)
        if USE_SAVGOL and len(smoothed_ma) > SAVGOL_WINDOW:
            smoothed[axis] = savgol_filter(smoothed_ma, SAVGOL_WINDOW, SAVGOL_POLYORDER)
        else:
            smoothed[axis] = smoothed_ma
    
    return smoothed


def save_data_to_csv(accel_data, gyro_data, timestamps, filename="imu_recording.csv"):
    """Save IMU data to CSV file"""
    with open(filename, 'w', newline='') as f:
        writer = csv.writer(f)
        writer.writerow(['Time(s)', 'Ax', 'Ay', 'Az', 'Gx', 'Gy', 'Gz'])
        
        for i, t in enumerate(timestamps):
            row = [
                f"{t:.3f}",
                f"{accel_data['x'][i]:.4f}",
                f"{accel_data['y'][i]:.4f}",
                f"{accel_data['z'][i]:.4f}",
                f"{gyro_data['x'][i]:.4f}",
                f"{gyro_data['y'][i]:.4f}",
                f"{gyro_data['z'][i]:.4f}"
            ]
            writer.writerow(row)
    
    print(f"[✓] Data saved to {filename}")


def animate_all_data(accel_smooth, gyro_smooth, timestamps):
    """
    Create animated visualization of 10 seconds of IMU data
    Shows 3D trajectory, 3D rotating cube, and time-series data updating in real-time
    """
    # Pre-calculate angular displacement for animation
    dt = np.mean(np.diff(timestamps)) if len(timestamps) > 1 else 0.03
    angle_x = np.cumsum(gyro_smooth["x"]) * dt
    angle_y = np.cumsum(gyro_smooth["y"]) * dt
    angle_z = np.cumsum(gyro_smooth["z"]) * dt
    gyro_magnitude = np.sqrt(
        gyro_smooth["x"]**2 + gyro_smooth["y"]**2 + gyro_smooth["z"]**2
    )
    
    # Create figure with 4 subplots
    fig = plt.figure(figsize=(15, 12))
    
    # 3D Accelerometer plot
    ax1 = fig.add_subplot(2, 2, 1, projection='3d')
    ax1.set_xlim([-0.5, 0.5])
    ax1.set_ylim([-0.5, 0.5])
    ax1.set_zlim([-0.5, 0.5])
    ax1.set_xlabel('X Acceleration')
    ax1.set_ylabel('Y Acceleration')
    ax1.set_zlabel('Z Acceleration')
    ax1.set_title('3D Accelerometer Trajectory')
    line_3d, = ax1.plot([], [], [], 'b-', linewidth=1, alpha=0.7)
    point_3d, = ax1.plot([], [], [], 'ro', markersize=8)
    
    # 3D Rotating Cube plot
    ax2 = fig.add_subplot(2, 2, 2, projection='3d')
    ax2.set_xlim([-0.5, 0.5])
    ax2.set_ylim([-0.5, 0.5])
    ax2.set_zlim([-0.5, 0.5])
    ax2.set_xlabel('X')
    ax2.set_ylabel('Y')
    ax2.set_zlabel('Z')
    ax2.set_title('3D Angular Motion - Rotating Cube')
    
    # Time-series accelerometer
    ax3 = fig.add_subplot(2, 2, 3)
    ax3.set_xlim([0, max(timestamps)])
    ax3.set_ylim([-0.5, 0.5])
    ax3.set_xlabel('Time (s)')
    ax3.set_ylabel('Acceleration')
    ax3.set_title('Accelerometer Time-Series')
    ax3.grid(True, alpha=0.3)
    line_x, = ax3.plot([], [], 'r-', linewidth=1.5, label='Ax')
    line_y, = ax3.plot([], [], 'g-', linewidth=1.5, label='Ay')
    line_z, = ax3.plot([], [], 'b-', linewidth=1.5, label='Az')
    ax3.legend(loc='upper left')
    
    # Angular velocity magnitude
    ax4 = fig.add_subplot(2, 2, 4)
    ax4.set_xlim([0, max(timestamps)])
    ax4.set_ylim([0, max(gyro_magnitude) * 1.1 if len(gyro_magnitude) > 0 else 1])
    ax4.set_xlabel('Time (s)')
    ax4.set_ylabel('Angular Velocity (rad/s)')
    ax4.set_title('Total Rotation Speed')
    ax4.grid(True, alpha=0.3)
    line_gyro, = ax4.plot([], [], 'purple', linewidth=2)
    
    # Time text
    time_text = fig.text(0.5, 0.02, '', ha='center', fontsize=14, fontweight='bold')
    
    def rotation_matrix_3d(rx, ry, rz):
        """Create 3D rotation matrix from Euler angles (XYZ convention)"""
        # Rotation around X axis
        Rx = np.array([
            [1, 0, 0],
            [0, np.cos(rx), -np.sin(rx)],
            [0, np.sin(rx), np.cos(rx)]
        ])
        
        # Rotation around Y axis
        Ry = np.array([
            [np.cos(ry), 0, np.sin(ry)],
            [0, 1, 0],
            [-np.sin(ry), 0, np.cos(ry)]
        ])
        
        # Rotation around Z axis
        Rz = np.array([
            [np.cos(rz), -np.sin(rz), 0],
            [np.sin(rz), np.cos(rz), 0],
            [0, 0, 1]
        ])
        
        return Rz @ Ry @ Rx
    
    def draw_3d_cube(ax, rotation_matrix, color='cyan', alpha=0.6):
        """Draw a rotated cube"""
        # Define cube vertices
        cube_size = 0.2
        vertices = np.array([
            [-cube_size, -cube_size, -cube_size],
            [cube_size, -cube_size, -cube_size],
            [cube_size, cube_size, -cube_size],
            [-cube_size, cube_size, -cube_size],
            [-cube_size, -cube_size, cube_size],
            [cube_size, -cube_size, cube_size],
            [cube_size, cube_size, cube_size],
            [-cube_size, cube_size, cube_size]
        ])
        
        # Apply rotation
        rotated = vertices @ rotation_matrix.T
        
        # Draw cube edges
        edges = [
            [0, 1], [1, 2], [2, 3], [3, 0],  # Bottom face
            [4, 5], [5, 6], [6, 7], [7, 4],  # Top face
            [0, 4], [1, 5], [2, 6], [3, 7]   # Vertical edges
        ]
        
        for edge in edges:
            points = rotated[edge]
            ax.plot3D(*points.T, 'b-', linewidth=2)
        
        # Draw center
        ax.scatter(0, 0, 0, c='r', s=100, marker='o')
    
    def update_frame(frame):
        # Limit trail length
        start_idx = max(0, frame - TRAIL_LENGTH)
        
        # Update 3D trajectory
        x_trail = accel_smooth["x"][start_idx:frame+1]
        y_trail = accel_smooth["y"][start_idx:frame+1]
        z_trail = accel_smooth["z"][start_idx:frame+1]
        line_3d.set_data(x_trail, y_trail)
        line_3d.set_3d_properties(z_trail)
        
        # Update current point
        point_3d.set_data([accel_smooth["x"][frame]], [accel_smooth["y"][frame]])
        point_3d.set_3d_properties([accel_smooth["z"][frame]])
        
        # Update 3D rotating cube
        ax2.clear()
        ax2.set_xlim([-0.5, 0.5])
        ax2.set_ylim([-0.5, 0.5])
        ax2.set_zlim([-0.5, 0.5])
        ax2.set_xlabel('X')
        ax2.set_ylabel('Y')
        ax2.set_zlabel('Z')
        ax2.set_title('3D Angular Motion - Rotating Cube')
        
        # Get rotation matrix from angular displacements
        R = rotation_matrix_3d(angle_x[frame], angle_y[frame], angle_z[frame])
        draw_3d_cube(ax2, R, color='cyan', alpha=0.6)
        
        # Update time-series
        t_data = timestamps[0:frame+1]
        line_x.set_data(t_data, accel_smooth["x"][0:frame+1])
        line_y.set_data(t_data, accel_smooth["y"][0:frame+1])
        line_z.set_data(t_data, accel_smooth["z"][0:frame+1])
        
        # Update gyro magnitude
        line_gyro.set_data(t_data, gyro_magnitude[0:frame+1])
        
        # Update time display
        time_text.set_text(f'Time: {timestamps[frame]:.2f}s / {max(timestamps):.2f}s')
        
        return line_3d, point_3d, line_x, line_y, line_z, line_gyro
    
    # Create animation
    num_frames = len(timestamps)
    ani = FuncAnimation(fig, update_frame, frames=num_frames, 
                       interval=30, blit=False, repeat=True)
    
    plt.tight_layout(rect=[0, 0.03, 1, 1])
    plt.show()


def plot_3d_visualization(accel_smooth, gyro_smooth, timestamps):
