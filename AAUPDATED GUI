    def play_video(self, video_path, speed_multiplier=3.0):
        """Play a video file using OpenCV with adjustable speed"""
        with opencv_lock:
            try:
                cap = cv2.VideoCapture(video_path)
                if not cap.isOpened():
                    QMessageBox.critical(self, "Error", "Could not open video file")
                    return

                # Get video properties
                fps = cap.get(cv2.CAP_PROP_FPS)
                if fps <= 0:
                    fps = 30  # Default fallback
                
                # Calculate frame delay (faster playback)
                base_delay = int(1000 / fps)  # Original speed
                current_speed = speed_multiplier  # Use parameter
                frame_delay = max(1, int(base_delay / current_speed))  # Faster speed

                # Create a window for video playback
                window_name = "Paddle Swing Video (Q=quit, SPACE=pause, ↑=faster, ↓=slower)"
                cv2.namedWindow(window_name, cv2.WINDOW_NORMAL)
                cv2.resizeWindow(window_name, 800, 600)

                close_requested = False

                while cap.isOpened():
                    ret, frame = cap.read()
                    if not ret:
                        break

                    cv2.imshow(window_name, frame)
                    
                    # Handle keyboard input
                    key = cv2.waitKey(frame_delay) & 0xFF
                    if key == ord('q'):
                        close_requested = True
                        break
                    elif key == 32:  # Spacebar to pause/unpause
                        cv2.waitKey(0)  # Wait indefinitely until any key
                    elif key == 82:  # Up arrow - faster
                        current_speed = min(current_speed * 1.5, 8.0)
                        frame_delay = max(1, int(base_delay / current_speed))
                        print(f"Speed: {current_speed}x")
                    elif key == 84:  # Down arrow - slower
                        current_speed = max(current_speed / 1.5, 0.25)
                        frame_delay = max(1, int(base_delay / current_speed))
                        print(f"Speed: {current_speed}x")
                    
                    if cv2.getWindowProperty(window_name, cv2.WND_PROP_VISIBLE) < 1:
                        close_requested = True
                        break

                if not close_requested:
                    self.status_label.setText("▶ Playback finished. Press any key to close window")
                    cv2.waitKey(0)

                cap.release()
                cv2.destroyAllWindows()

            except Exception as e:
                QMessageBox.critical(self, "Error", f"Failed to play video:\n{e}")

    # -------- COUNTDOWN --------
    def countdown(self, t):
        if t > 0:
            self.status_label.setText(f"⏳ Recording starts in {t}...")
            QTimer.singleShot(1000, lambda: self.countdown(t-1))
        else:
            self.status_label.setText("🔴 Recording NOW")
            threading.Thread(target=self.run_pipeline, daemon=True).start()

    # -------- PIPELINE --------
    def run_pipeline(self):
        asyncio.run(self.pipeline())

    async def pipeline(self):

        await record_motion()

        if len(ax_data) < 5:
            QTimer.singleShot(0, lambda: self.status_label.setText("❌ Not enough data"))
            self.running = False
            return
        if len(ax_data) == 0:
            QTimer.singleShot(0, lambda: self.status_label.setText("❌ Device not found"))
            self.running = False
            return

        ax, ay, az, gx, gy, gz = resample_data(
            ax_data, ay_data, az_data, gx_data, gy_data, gz_data
        )

        orientations = compute_orientation(ax, ay, az, gx, gy, gz)
        positions = compute_swing_translation(orientations, ax, ay, az)

        target_frames = int(RECORD_TIME * ANIMATION_FPS * 1.2)
        orientations, positions = interpolate_motion(
            orientations, positions, target_frames
        )

        mesh = pv.read(STL_FILE)
        mesh.translate(-np.array([0.15, 0, 0]))
        mesh.rotate_y(90)
        mesh.scale([0.10, 0.10, 0.10])

        # -------- SAFE UI SETUP --------
        def setup_scene():
            self.plotter.clear()
            self.plotter.add_axes()
            self.actor = self.plotter.add_mesh(
                mesh, color="darkgreen", smooth_shading=True
            )
            self.plotter.reset_camera()

        QTimer.singleShot(0, setup_scene)

        writer = imageio.get_writer(self.video_path, fps=ANIMATION_FPS)

        prev_rot = None

        for orientation, pos in zip(orientations, positions):

            rot = orientation.as_euler("xyz", degrees=True)
            if prev_rot is not None:
                rot = prev_rot * 0.7 + np.array(rot) * 0.3
            prev_rot = rot

            # -------- SAFE FRAME UPDATE --------
            def update_frame(rot=rot, pos=pos):
                try:
                    self.actor.SetOrientation(rot)
                    self.actor.SetPosition(pos)
                    self.plotter.render()
                    frame = self.plotter.screenshot(return_img=True)
                    writer.append_data(frame)
                except:
                    pass

            QTimer.singleShot(0, update_frame)
            QTimer.singleShot(int(1000 / ANIMATION_FPS), lambda: None)

        writer.close()

        def finish():
            self.status_label.setText("✅ Done!")
            
            # Show dialog with options to open or browse
            result = QMessageBox.question(
                self,
                "Video Saved",
                f"Video saved to:\n{self.video_path}\n\nWhat would you like to do?",
                QMessageBox.Open | QMessageBox.Cancel
            )
            
            if result == QMessageBox.Open:
                os.startfile(self.video_path)

        QTimer.singleShot(0, finish)

        self.running = False

    # -------- VIDEO LIST MANAGEMENT --------
    def refresh_video_list(self):
        """Scan folder for MP4 files and populate list"""
        self.video_list.clear()
        
        # Get all MP4 files in script directory
        video_files = []
        try:
            for file in os.listdir(SCRIPT_DIR):
                if file.lower().endswith('.mp4'):
                    video_files.append(file)
        except Exception as e:
            print(f"[!] Error scanning directory: {e}")
        
        # Sort by modification time (newest first)
        video_files.sort(key=lambda x: os.path.getmtime(os.path.join(SCRIPT_DIR, x)), reverse=True)
        
        # Add to list widget
        for video_file in video_files:
            item = QListWidgetItem(video_file)
            item.setData(Qt.UserRole, os.path.join(SCRIPT_DIR, video_file))
            self.video_list.addItem(item)
        
        if video_files:
            self.video_list.setCurrentRow(0)
    
    def browse_and_play_video(self):
        """Browse and play any video file"""
        file_path, _ = QFileDialog.getOpenFileName(
            self,
            "Select Video File",
            SCRIPT_DIR,
            "MP4 Videos (*.mp4);;All Files (*)"
        )
        
        if file_path and os.path.exists(file_path):
            self.play_video_opencv(file_path)
    
    def play_selected_video(self):
        """Play the selected video from the list"""
        current_item = self.video_list.currentItem()
        if not current_item:
            QMessageBox.warning(self, "No Selection", "Please select a video to play.")
            return
        
        video_path = current_item.data(Qt.UserRole)
        self.play_video_opencv(video_path)
    
    def play_video_opencv(self, video_path):
        """Play video using OpenCV in a new window"""
        if not os.path.exists(video_path):
            QMessageBox.warning(self, "File Not Found", f"Video file not found:\n{video_path}")
            return
        
        # Check if this video is already being played
        for window in self.video_windows:
            if window.windowTitle().endswith(os.path.basename(video_path)):
                QMessageBox.information(self, "Video Already Playing", 
                                      f"'{os.path.basename(video_path)}' is already playing in another window.")
                window.raise_()
                window.activateWindow()
                return
        
        # Create video window
        video_window = QWidget()
        video_window.setWindowTitle(f"Video Player - {os.path.basename(video_path)}")
        video_window.resize(960, 720)
        
        layout = QVBoxLayout(video_window)
        
        # Video display label
        video_label = QLabel()
        video_label.setAlignment(Qt.AlignCenter)
        layout.addWidget(video_label)
        
        # Control buttons
        control_layout = QHBoxLayout()
        
        play_btn = QPushButton("Play")
        pause_btn = QPushButton("Pause")
        stop_btn = QPushButton("Stop")
        speed_btn = QPushButton("4x Speed")  # Updated default
        fullscreen_btn = QPushButton("Full Screen")
        
        control_layout.addWidget(play_btn)
        control_layout.addWidget(pause_btn)
        control_layout.addWidget(stop_btn)
        control_layout.addWidget(speed_btn)
        control_layout.addWidget(fullscreen_btn)
        control_layout.addStretch()
        
        layout.addLayout(control_layout)
        
        # Video player state
        class VideoPlayer:
            def __init__(self):
                with opencv_lock:
                    self.cap = cv2.VideoCapture(video_path)
                    if not self.cap.isOpened():
                        raise Exception(f"Cannot open video: {video_path}")
                
                self.fps = self.cap.get(cv2.CAP_PROP_FPS)
                self.total_frames = int(self.cap.get(cv2.CAP_PROP_FRAME_COUNT))
                self.base_frame_delay = max(1, int(1000 / self.fps)) if self.fps > 0 else 33
                self.speed_multiplier = 2.0  # Start at 2x speed instead of 1x
                self.frame_delay = int(self.base_frame_delay / self.speed_multiplier)
                self.is_playing = False
                self.current_frame = 0
                self.playback_thread = None
                self.should_stop = False
            
            def set_speed(self, multiplier):
                self.speed_multiplier = multiplier
                self.frame_delay = max(1, int(self.base_frame_delay / self.speed_multiplier))
            
            def release(self):
                with opencv_lock:
                    if self.cap.isOpened():
                        self.cap.release()
        
        try:
            player = VideoPlayer()
        except Exception as e:
            QMessageBox.critical(self, "Video Error", f"Cannot open video:\n{str(e)}")
            return
        
        def show_frame(frame_num):
            with opencv_lock:
                player.cap.set(cv2.CAP_PROP_POS_FRAMES, frame_num)
                ret, frame = player.cap.read()
                
                if not ret:
                    return
                
                # Convert BGR to RGB
                frame_rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
                h, w, ch = frame_rgb.shape
                
                # Convert to QImage
                bytes_per_line = 3 * w
                qt_image = QImage(frame_rgb.data, w, h, bytes_per_line, QImage.Format_RGB888)
                
                # Scale to fit label
                pixmap = QPixmap.fromImage(qt_image)
                scaled_pixmap = pixmap.scaledToWidth(video_label.width() - 20, Qt.SmoothTransformation)
                video_label.setPixmap(scaled_pixmap)
                
                player.current_frame = frame_num
        
        def play_video_thread():
            """Thread function for video playback"""
            import time
            while player.is_playing and not player.should_stop:
                if player.current_frame < player.total_frames - 1:
                    player.current_frame += 1
                    show_frame(player.current_frame)
                    time.sleep(player.frame_delay / 1000.0)
                else:
                    player.is_playing = False
                    play_btn.setText("Play")
                    pause_btn.setText("Pause")
        
        def play_video():
            if not player.is_playing:
                player.is_playing = True
                play_btn.setText("Playing")
                pause_btn.setText("Pause")
                player.playback_thread = threading.Thread(target=play_video_thread, daemon=True)
                player.playback_thread.start()
        
        def pause_video():
            if player.is_playing:
                player.is_playing = False
                play_btn.setText("Play")
                pause_btn.setText("Paused")
        
        def toggle_play():
            if player.is_playing:
                pause_video()
            else:
                play_video()
        
        def stop_video():
            pause_video()
            player.current_frame = 0
            show_frame(0)
            play_btn.setText("Play")
            pause_btn.setText("Pause")
        
        def toggle_speed():
            if player.speed_multiplier == 2.0:
                player.set_speed(4.0)
                speed_btn.setText("8x Speed")
            elif player.speed_multiplier == 4.0:
                player.set_speed(8.0)
                speed_btn.setText("1x Speed")
            else:  # 8.0
                player.set_speed(1.0)
                speed_btn.setText("2x Speed")
        
        def toggle_fullscreen():
            if video_window.isFullScreen():
                video_window.showNormal()
                fullscreen_btn.setText("Full Screen")
            else:
                video_window.showFullScreen()
                fullscreen_btn.setText("Exit Full Screen")
        
        # Connect buttons
        play_btn.clicked.connect(toggle_play)
        pause_btn.clicked.connect(pause_video)
        stop_btn.clicked.connect(stop_video)
        speed_btn.clicked.connect(toggle_speed)
        fullscreen_btn.clicked.connect(toggle_fullscreen)
        
        # Cleanup when window closes
        def cleanup():
            player.should_stop = True
            player.is_playing = False
            player.release()
            if video_window in self.video_windows:
                self.video_windows.remove(video_window)
        
        video_window.destroyed.connect(cleanup)
        self.video_windows.append(video_window)
        
        # Show first frame and window
        show_frame(0)
        video_window.show()

