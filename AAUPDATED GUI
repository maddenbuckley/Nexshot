# ---------------- WORKER THREAD ----------------
class RecordingWorker(QThread):
    """Worker thread for BLE recording and animation"""
    status_update = pyqtSignal(str)  # Status messages
    finished = pyqtSignal(str)  # Video path when done
    error = pyqtSignal(str)  # Error messages

    def __init__(self, video_path):
        super().__init__()
        self.video_path = video_path

    def run(self):
        """Run the recording and animation pipeline"""
        try:
            self.status_update.emit("🔄 Starting recording...")
            
            # Run async recording
            try:
                asyncio.run(self._async_pipeline())
            except RuntimeError:
                # Handle event loop issues
                loop = asyncio.new_event_loop()
                asyncio.set_event_loop(loop)
                loop.run_until_complete(self._async_pipeline())
                loop.close()

        except Exception as e:
            self.status_update.emit(f"[!] Error: {e}")
            import traceback
            self.status_update.emit(traceback.format_exc())
            self.error.emit(str(e))

    async def _async_pipeline(self):
        """Async pipeline implementation"""
        # Record motion (live UI status updates)
        await record_motion(lambda msg: self.status_update.emit(msg))

        if len(ax_data) < 5:
            self.status_update.emit("❌ Not enough data")
            self.error.emit("Not enough motion data recorded")
            return
        if len(ax_data) == 0:
            self.status_update.emit("❌ Device not found")
            self.error.emit("BLE device not found")
            return

        self.status_update.emit(f"[✓] Recorded {len(ax_data)} samples")

        # Process data
        ax, ay, az, gx, gy, gz = resample_data(
            ax_data, ay_data, az_data, gx_data, gy_data, gz_data
        )

        orientations = compute_orientation(ax, ay, az, gx, gy, gz)
        positions = compute_swing_translation(orientations, ax, ay, az)

        target_frames = int(RECORD_TIME * ANIMATION_FPS * 1.2)  # Reduced from 2x to 1.2x for faster videos
        orientations, positions = interpolate_motion(
            orientations, positions, target_frames
        )

        self.status_update.emit("[*] Creating animation...")

        # Create animation (this part is synchronous)
        self._create_animation(orientations, positions)

        self.status_update.emit("✅ Animation complete!")
        self.finished.emit(self.video_path)

    def _create_animation(self, orientations, positions):
        """Create the animation synchronously"""
        mesh = pv.read(STL_FILE)
        mesh.translate(-np.array([0.15, 0, 0]))
        mesh.rotate_y(90)
        mesh.scale([0.2, 0.2, 0.2])  # Reduced scale to keep paddle fully visible in video

        plotter = pv.Plotter(off_screen=True, window_size=(800, 608))  # Divisible by 16 for video codec compatibility
        actor = plotter.add_mesh(mesh, color="darkgreen", smooth_shading=False)  # Disable smooth shading for speed
        plotter.add_axes(line_width=1)  # Simpler axes
        plotter.set_background("white")
        plotter.show(auto_close=False)
        plotter.reset_camera()  # Ensure the entire paddle is visible in the frame

        writer = imageio.get_writer(self.video_path, fps=ANIMATION_FPS, macro_block_size=16, 
                                   format='mp4', codec='libx264', 
                                   quality=8, pixelformat='yuv420p')

        prev_rot = None

        try:
            for i, (orientation, pos) in enumerate(zip(orientations, positions)):
                rot = orientation.as_euler("xyz", degrees=True)
                if prev_rot is not None:
                    rot = prev_rot * 0.7 + np.array(rot) * 0.3
                prev_rot = rot

                actor.SetOrientation(rot)
                actor.SetPosition(pos)
                plotter.render()
                frame = plotter.screenshot(return_img=True)
                writer.append_data(frame)

                if i % 50 == 0:
                    progress = (i / len(orientations)) * 100
                    self.status_update.emit(f"[*] Rendering: {progress:.1f}%")

        except Exception as e:
            print(f"Error during animation: {e}")
            import traceback
            traceback.print_exc()
        finally:
            writer.close()
            plotter.close()

# ---------------- PADDLE VIEWER ----------------
class PaddleViewer(QWidget):
    def __init__(self, parent=None):
        super().__init__(parent)
        self.plotter = None  # Initialize later to avoid OpenGL context issues
        
        main = QVBoxLayout(self)
        # Placeholder widget until plotter is initialized
        self.placeholder = QLabel("Loading 3D viewer...")
        self.placeholder.setAlignment(Qt.AlignCenter)
        main.addWidget(self.placeholder)

        bar = QHBoxLayout()
        self.back_btn = QPushButton("Back")
        bar.addWidget(self.back_btn)
        bar.addStretch()
        main.addLayout(bar)
        
        # Initialize plotter when widget is shown
        self.shown = False

    def showEvent(self, event):
        super().showEvent(event)
        if not self.shown:
            self.shown = True
            self._init_plotter()

    def _init_plotter(self):
        """Initialize the plotter safely"""
        with vtk_lock:
            try:
                # Remove placeholder
                layout = self.layout()
                layout.removeWidget(self.placeholder)
                self.placeholder.hide()
                
                # Create plotter
                self.plotter = QtInteractor(self)
                layout.insertWidget(0, self.plotter.interactor)
                
                # Load default model
                self.load_default()
                
            except Exception as e:
                print(f"Failed to initialize 3D viewer: {e}")
                import traceback
                traceback.print_exc()
                
                error_label = QLabel(f"3D Viewer Error:\n{str(e)}")
                error_label.setAlignment(Qt.AlignCenter)
                error_label.setStyleSheet("color: red; font-size: 10px;")
                layout = self.layout()
                layout.insertWidget(0, error_label)

    def load_default(self):
        if self.plotter is None:
            return  # Plotter not initialized yet
            
        script_dir = os.path.dirname(os.path.abspath(__file__))
        path = os.path.join(script_dir, "paddle.stl")

        if not os.path.exists(path):
            QMessageBox.warning(self, "Missing file", f"Could not find paddle.stl in {script_dir}")
            self.plotter.clear()
            self.plotter.add_axes()
            self.plotter.add_mesh(pv.Cube(), color="gray", opacity=0.4)
            self.plotter.reset_camera()
            return

        try:
            mesh = pv.read(path)
            self.plotter.clear()
            self.plotter.add_axes()
            self.plotter.add_mesh(mesh, show_edges=False, smooth_shading=True, color="darkgreen")
            self.plotter.reset_camera()
            self.plotter.view_isometric()
        except Exception as e:
            QMessageBox.critical(self, "Error", f"Failed to load STL:\n{e}")


