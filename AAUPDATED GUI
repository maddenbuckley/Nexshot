        if ok and filename:
            # Ensure .mp4 extension
            if not filename.endswith('.mp4'):
                filename += '.mp4'
            
            new_path = os.path.join(SCRIPT_DIR, filename)
            
            try:
                os.rename(video_path, new_path)
                self.video_path = new_path
                QMessageBox.information(self, "Saved", f"Video saved as:\n{filename}")
            except Exception as e:
                QMessageBox.warning(self, "Error", f"Could not rename file:\n{e}")
        
