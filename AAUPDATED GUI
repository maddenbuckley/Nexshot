RECORD_TIME = 10
ANIMATION_FPS = 60  # Increased from 120 for faster playback
SMOOTH_WINDOW = 50

TRANSLATION_SCALE = 0.1
GYRO_WEIGHT = 0.8

# ---------------- DATA STORAGE ----------------
ax_data, ay_data, az_data = [], [], []
gx_data, gy_data, gz_data = [], [], []

# ---------------- BLE RECORDING ----------------
async def record_motion(status_callback=None):

    def _status(msg):
        print(msg)
        if status_callback:
            status_callback(msg)

    _status("Scanning for device...")
    devices = await BleakScanner.discover()
    device = next((d for d in devices if d.name == DEVICE_NAME), None)

    if not device:
        _status("Device not found")
        return

    _status(f"Connecting to {device.address}")

    async with BleakClient(device.address) as client:

        def notification_handler(sender, data):

            try:
                #text = data.decode().strip()
                #vals = text.replace(",", " ").split()
                vals = np.frombuffer(data, dtype=np.float32)

                if len(vals) < 6:
                    return

                ax, ay, az, gx, gy, gz = vals

                ax_data.append(ax)
                ay_data.append(ay)
                az_data.append(az)

                gx_data.append(gx)
                gy_data.append(gy)
                gz_data.append(gz)

            except:
                pass

        print("Recording Motion...")
        _status("Recording Motion...")
        await client.start_notify(CHAR_UUID, notification_handler)

        await asyncio.sleep(RECORD_TIME)

        await client.stop_notify(CHAR_UUID)

    print("Recording finished")
    print("Samples captured:", len(ax_data))
    print("Sample rate:", len(ax_data) / RECORD_TIME, "Hz")

# ---------------- SMOOTH ----------------
def smooth_data(data):

    if len(data) < SMOOTH_WINDOW:
        return np.array(data)

    return savgol_filter(data, SMOOTH_WINDOW, 3)

# ---------------- RESAMPLE DATA ----------------
def resample_data(ax, ay, az, gx, gy, gz, target_rate=200):
    ts = np.arange(len(ax)) / (len(ax) / RECORD_TIME)
    t_uniform = np.arange(ts[0], ts[-1], 1.0 / target_rate)
    
    cs_ax = CubicSpline(ts, ax)
    cs_ay = CubicSpline(ts, ay)
    cs_az = CubicSpline(ts, az)
    cs_gx = CubicSpline(ts, gx)
    cs_gy = CubicSpline(ts, gy)
    cs_gz = CubicSpline(ts, gz)
    
    ax_u = cs_ax(t_uniform)
    ay_u = cs_ay(t_uniform)
    az_u = cs_az(t_uniform)
    gx_u = cs_gx(t_uniform)
    gy_u = cs_gy(t_uniform)
    gz_u = cs_gz(t_uniform)
    
    return ax_u, ay_u, az_u, gx_u, gy_u, gz_u

# ---------------- ORIENTATION ----------------
def compute_orientation(ax, ay, az, gx, gy, gz):

    ax = smooth_data(ax)
    ay = smooth_data(ay)
    az = smooth_data(az)

    gx = smooth_data(gx)
    gy = smooth_data(gy)
    gz = smooth_data(gz)

    orientations = []
    orientation = R.identity()

    dt = RECORD_TIME/(len(ax))

    for i in range(len(ax)):

        gyro_vec = np.array([gx[i], gy[i], gz[i]]) * np.pi/180 * dt
        gyro_rot = R.from_rotvec(gyro_vec)

        orientation = orientation * gyro_rot

        g = np.array([ax[i], ay[i], az[i]])
        norm = np.linalg.norm(g)
        if norm == 0:
            continue
        g /= norm

        pitch = np.arctan2(-g[0], np.sqrt(g[1]**2 + g[2]**2))
        roll = np.arctan2(g[1], g[2])

        accel_rot = R.from_euler('xy', [pitch, roll])

        key_times = [0,1]
        key_rots = R.concatenate([orientation, accel_rot])

        slerp = Slerp(key_times, key_rots)
        orientation = slerp([GYRO_WEIGHT])[0]

        orientations.append(orientation)

    base = orientations[0].inv()
    orientations = [base * o for o in orientations]

    return orientations

# ---------------- TRANSLATION ----------------
def compute_swing_translation(orientations, ax, ay, az):

    dt = RECORD_TIME / len(ax)

    velocity = np.zeros(3)
    position = np.zeros(3)

    positions = []

    for i in range(len(ax)):

        acc_body = np.array([ax[i], ay[i], az[i]])

        # convert to world frame
        acc_world = orientations[i].apply(acc_body)

        # remove gravity (approx)
        acc_world[2] -= 1.0

        velocity += acc_world * dt
        position += velocity * dt

        positions.append(position.copy())

    positions = np.array(positions)

    # smooth result
    for i in range(3):
        positions[:, i] = savgol_filter(positions[:, i], 21, 3)

    # Scale down translation for paddle swing
    positions *= TRANSLATION_SCALE

    return positions

# -------- INTERPOLATE FOR SMOOTHER MOTION --------
def interpolate_motion(orientations, positions, target_frames):

    n_keyframes = len(orientations)

    if n_keyframes < 4:
        return orientations, positions

    time_original = np.linspace(0, 1, n_keyframes)
    time_interp = np.linspace(0, 1, target_frames)

    # -------- ORIENTATION INTERPOLATION (SLERP) --------
    key_rots = R.concatenate(orientations)
    slerp = Slerp(time_original, key_rots)
    interp_orientations = slerp(time_interp)

    # -------- POSITION INTERPOLATION --------
    interp_positions = np.zeros((target_frames, 3))

    for i in range(3):
        cs = CubicSpline(time_original, positions[:, i])
        interp_positions[:, i] = cs(time_interp)

    return list(interp_orientations), interp_positions
# -------- ANIMATION --------
def animate_paddle():
    if len(ax_data) < 5:
        print("Not enough motion data")
        return

    # Resample data
    ax, ay, az, gx, gy, gz = resample_data(ax_data, ay_data, az_data, gx_data, gy_data, gz_data)

    # compute orientation and positions
    orientations = compute_orientation(ax, ay, az, gx, gy, gz)
    positions = compute_swing_translation(orientations, ax, ay, az)
    path = pv.Spline(positions, 200)
    
    # Interpolate for smoother motion (slow motion effect)
    slow_motion_factor = 2  # Increase for slower playback (e.g., 2 = half speed)
    target_frames = int(RECORD_TIME * ANIMATION_FPS * slow_motion_factor)  # More frames for slower animation
    print(f"Interpolating from {len(orientations)} frames to {target_frames} frames...")
    orientations, positions = interpolate_motion(orientations, positions, target_frames)

    # read paddle mesh
    mesh = pv.read(STL_FILE)
    #mesh.translate(-np.array(mesh.center))
    handle_offset = np.array([0.15, 0, 0])  # adjust based on actual model    
    mesh.translate(-handle_offset)
    mesh.rotate_y(90)

    # scale paddle for visibility
    mesh.scale([0.35, 0.35, 0.35])

    plotter = pv.Plotter(off_screen=True, window_size=(912, 704))
    actor = plotter.add_mesh(
        mesh,
        color="darkgreen",
        smooth_shading=True
    )
    plotter.set_background("white")
    #plotter.add_mesh(path, color="red", line_width=4)
    plotter.add_axes()

